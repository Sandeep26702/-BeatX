<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Profile Info Section -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivUserImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="32dp"
        android:background="?attr/colorPrimaryContainer"
        android:src="@android:drawable/ic_menu_myplaces"
        app:tint="?attr/colorOnPrimaryContainer"
        android:scaleType="centerInside"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Guest User"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivUserImage" />

    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="guest@beatx.com"
        android:textSize="16sp"
        android:alpha="0.7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvName" />
        
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvEmail" />

    <!-- Menu Items -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/divider">
        
        <!-- Theme -->
        <TextView
            android:id="@+id/tvTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            android:text="Theme"
            android:textSize="18sp"
            app:drawableStartCompat="@android:drawable/ic_menu_agenda"
            android:drawablePadding="16dp"
            app:drawableTint="?attr/colorOnSurface" />

        <!-- Language -->
        <TextView
            android:id="@+id/tvLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            android:text="Language"
            android:textSize="18sp"
            app:drawableStartCompat="@android:drawable/ic_menu_sort_alphabetically"
            android:drawablePadding="16dp"
            app:drawableTint="?attr/colorOnSurface" />

        <!-- Logout -->
        <TextView
            android:id="@+id/tvLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            android:text="Logout"
            android:textSize="18sp"
            android:textColor="?attr/colorError"
            app:drawableStartCompat="@android:drawable/ic_menu_close_clear_cancel"
            android:drawablePadding="16dp"
            app:drawableTint="?attr/colorError" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
